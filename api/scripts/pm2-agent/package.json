{
  "name": "acs2i-test-agent",
  "version": "1.0.0",
  "description": "PM2 monitor agent: Socket.IO client that reports process list to the watcher server",
  "main": "dist/agent.cjs",
  "type": "module",
  "scripts": {
    "build": "node scripts/bundle.js",
    "build:sea": "npm run build && node scripts/build-sea.js",
    "start": "node dist/agent.cjs",
    "dev": "tsx watch src/index.ts"
  },
  "bin": {
    "agent": "./dist/agent.cjs"
  },
  "keywords": [
    "socket.io",
    "pm2",
    "agent",
    "sea"
  ],
  "license": "ISC",
  "dependencies": {
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "esbuild": "^0.24.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
